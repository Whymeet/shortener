# Caddy: реверс-прокси для коротких доменов с автоматическим TLS (On-Demand).
#
# Caddy слушает 80/443 на ЛЮБОЙ хост (список доменов живёт в БД, не здесь) и при первом
# TLS-handshake на новый домен сам выпускает Let's Encrypt-сертификат — предварительно
# спросив у приложения GET /internal/tls-allow?domain=<host>. Разрешение = строго 2xx
# (приложение отдаёт 200 только для активных доменов из БД). Сертификаты хранятся в томе
# caddy_data (/data) и автоматически продлеваются.
#
# Добавить новый домен = добавить+активировать в /admin + A-запись владельца на сервер.
# Конфиг при этом НЕ меняется и перезапуск не нужен.

{
	email {$ACME_EMAIL}
	on_demand_tls {
		ask http://shortener:8000/internal/tls-allow
	}
}

# HTTPS для любого хоста — сертификат по требованию
:443 {
	tls {
		on_demand
	}
	reverse_proxy shortener:8000 {
		header_up Host {host}        # приложение должно видеть реальный публичный домен (мультидомен)
	}
}

# HTTP → HTTPS (короткие ссылки, открытые по http, уводим на https).
# On-demand использует TLS-ALPN-01 на :443, поэтому этот редирект ACME не ломает.
:80 {
	redir https://{host}{uri} permanent
}
