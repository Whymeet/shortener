# Подключение к собственной БД микросервиса (имя хоста postgres = сервис в compose)
DATABASE_URL=postgresql://shortener:shortener@postgres:5432/shortener

# Общий секрет для POST /shorten. Сгенерировать: openssl rand -hex 32
API_KEY=change-me

# Разрешённые короткие домены (через запятую/пробел, БЕЗ схемы). Каждый — независимый
# шортенер, домен берётся из заголовка Host. Добавить новый домен = дописать сюда + DNS + TLS.
ALLOWED_DOMAINS=go.kybyshka-dev.ru,krokozaim.ru,nashzaim.ru
# Схема для сборки short_url в ответе (SHORT_URL_SCHEME://<домен>/<slug>).
# Публичные ссылки всегда https; для локального теста по http поставь http.
SHORT_URL_SCHEME=https

# Длина слага, алфавит (base62 по умолчанию: цифры+буквы) и тип редиректа (302 = со счётчиком кликов)
SLUG_LENGTH=5
SLUG_ALPHABET=0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz
REDIRECT_STATUS=302
